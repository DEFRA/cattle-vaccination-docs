model {
    extend apha {
 
        testExternal = frontend {
            title 'bTB Skin Testing Vet Portal'
            -> bTbInternalApi
            -> gio.defraId
            pVet -> testExternal
            aVet -> testExternal
            aho -> testExternal
        }
        testApi = component {
            title 'bTb Testing API'
            description 'API for VDPs to retrieve work and submit results'
            -> bTbInternalApi
        }
        testInternal = component {
            title 'bTB Testing Internal Screens & Flows'
            -> testRecord
            -> svoc
            -> integrationBridge
            -> vaxRecord
            -> Livestock.integrationLayer
            bTbInternalApi -> testInternal
            aAdmin -> testInternal
            aVet -> testInternal

        }
        testRecord = storage {
            title 'bTB Test and Incident Records'
            -> svocRecords
            .etl epiData.cattleTbData
            .etl epiData.RADAR
        }
    }
}

deployment {
    extend Salesforce {
        instanceOf testInternal
        instanceOf testRecord
    }
    extend CDP {
        instanceOf testExternal
        instanceOf testApi
    }
}
