model{
    apha = context {
        title 'APHA systems'
        description 'Bounded context for APHA systems'


        Sam = externalSystem {
            title 'Sam'
            description 'Disease and customer management, user interface and engine'
            -> SamData
            -> Livestock.integrationLayer
            -> LIMS
            aho -> Sam
            aVet -> Sam
            aAdmin -> Sam
        }

        SamData = storage {
            title 'Sam Data'
            .etl epiData.cattleTbData
            .etl epiData.RADAR
        }

        iSam = externalSystem {
            title 'iSam'
            description 'Limited view of Sam, accessed via Government Gateway, for non-APHA users such as OVs.'
            vVet -> iSam
            vAtt -> iSam
            vAdmin -> iSam
            pVet -> iSam
            -> Sam
            -> govGateway
        }

        LIMS = externalSystem {
            description 'Laboratory Information Management System'
        }
    }

    govGateway = externalSystem {
        title 'Government Gateway'
        description 'Identity provider'
    }

    TOM = externalSystem {
        title 'Farmcare UK - Transaction Operation Manager'
        description 'Example of a VDP system'

        vAdmin -> TOM
        vVet -> TOM
        vAtt -> TOM
        TOM -> apha.testApi
    }
}

deployment {
    extend PEGA {
        instanceOf Sam
        instanceOf iSam
        instanceOf SamData
    }

    extend LIMS {
        instanceOf LIMS
    }
}